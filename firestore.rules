rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /sessions/{sessionId} {
      allow list, get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && isValidSession(request.resource.data);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && isValidSession(request.resource.data);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      function isValidSession(data) {
        return data.userId == request.auth.uid 
          && data.timestamp is string 
          && data.durationMinutes is number
          && data.subject is string
          && data.perceivedComplexity is number
          && data.distractions is number
          && data.energyLevel is number
          && data.performanceScore is number
          && data.cognitiveDebitScore is number
          && data.sessionType is string
          && data.flowStateRating is number;
      }
    }

    match /reminders/{reminderId} {
      allow list, get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && isValidReminder(request.resource.data);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && isValidReminder(request.resource.data);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      function isValidReminder(data) {
        return data.userId == request.auth.uid 
          && data.subject is string 
          && data.timestamp is string
          && data.sessionType is string
          && data.notified is bool;
      }
    }
  }
}
