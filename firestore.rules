rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Blueprints ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'joinedAt', 'preferences'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.joinedAt is string // Format validated via server logic/manual review if possible
        && data.preferences is map
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128)
        && (data.get('lastDebitScore', 0) is number)
        && (data.get('lastAnalysisInsights', '') is string && data.get('lastAnalysisInsights', '').size() <= 5000)
        && (data.get('hasSeenTutorial', false) is bool);
    }

    function isValidLearningSession(data) {
      return data.keys().hasAll(['id', 'userId', 'timestamp', 'durationMinutes', 'subject', 'perceivedComplexity', 'distractions', 'energyLevel', 'performanceScore', 'cognitiveDebitScore', 'sessionType', 'studyEnvironment', 'flowStateRating'])
        && data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.subject is string && data.subject.size() <= 256
        && data.durationMinutes is number && data.durationMinutes > 0
        && data.perceivedComplexity is number
        && data.distractions is number
        && data.energyLevel is number
        && data.performanceScore is number
        && data.cognitiveDebitScore is number
        && data.sessionType is string
        && data.studyEnvironment is string
        && data.flowStateRating is number;
    }

    function isValidLearningReminder(data) {
      return data.keys().hasAll(['id', 'userId', 'subject', 'timestamp', 'sessionType', 'notified'])
        && data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.subject is string && data.subject.size() <= 256
        && data.notified is bool;
    }

    // --- Rules ---

    // Profiles
    match /profiles/{uid} {
      allow get: if isOwner(uid);
      allow create: if isVerifiedUser() && isValidId(uid) && isValidUserProfile(incoming());
      allow update: if isVerifiedUser() && isOwner(uid) && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && incoming().joinedAt == existing().joinedAt;
    }

    // Sessions
    match /sessions/{sessionId} {
      allow list: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow get: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && isValidId(sessionId) && isValidLearningSession(incoming());
      allow update: if isVerifiedUser() && existing().userId == request.auth.uid && isValidLearningSession(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isVerifiedUser() && resource.data.userId == request.auth.uid;
    }

    // Reminders
    match /reminders/{reminderId} {
      allow list: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow get: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && isValidId(reminderId) && isValidLearningReminder(incoming());
      allow update: if isVerifiedUser() && existing().userId == request.auth.uid && isValidLearningReminder(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isVerifiedUser() && resource.data.userId == request.auth.uid;
    }
  }
}
